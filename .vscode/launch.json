{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "web_development",
            "request": "launch",
            "type": "dart",
            "deviceId": "chrome",
            "args": [
                "--web-hostname",
                "localhost",
                "--web-port",
                "9090",
                "--dart-define",
                "env=dev",
            ],
        },
        {
            "name": "web_production",
            "request": "launch",
            "type": "dart",
            "deviceId": "chrome",
            "args": [
                "--web-hostname",
                "localhost",
                "--web-port",
                "9090",
                "--dart-define",
                "env=real",
            ],
        },
        {
            "name": "android_development",
            "request": "launch",
            "type": "dart",
            "deviceId": "flutter_emulator",
            "args": [
                "--dart-define",
                "env=dev",
            ],
        },
        {
            "name": "android_production",
            "request": "launch",
            "type": "dart",
            "deviceId": "flutter_emulator",
            "args": [
                "--dart-define",
                "env=real",
            ],
        },
    ]
}